# ============================================================================
# WHATSAPP ASSISTANT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_KEY=your-secret-api-key-here

# ============================================================================
# DATABASE (MySQL)
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=your-database-password
DATABASE_NAME=wa_assistant

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=your-jwt-secret-key-min-32-characters
JWT_EXPIRES_IN=24h

# ============================================================================
# META WHATSAPP API
# ============================================================================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_CATALOG_ID=your-catalog-id
META_VERIFY_TOKEN=your-meta-verify-token

# ============================================================================
# OPENAI
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# GROQ (Alternative AI Provider)
# ============================================================================
GROQ_API_KEY=your-groq-api-key

# ============================================================================
# XENDIT PAYMENT (NEW)
# ============================================================================
# API Key dari Xendit Dashboard (https://dashboard.xendit.co)
XENDIT_API_KEY=xnd_your_xendit_api_key_here
# Optional: Xendit API URL (default: https://api.xendit.co)
XENDIT_API_URL=https://api.xendit.co
# Optional: Sub-Account ID jika menggunakan Xendit Sub-Account
XENDIT_SUB_ACCOUNT_ID=
# Optional: Webhook token untuk verifikasi callback dari Xendit
XENDIT_WEBHOOK_TOKEN=your_webhook_token_here

# ============================================================================
# PLATFORM FEE CONFIGURATION (NEW)
# ============================================================================
# Tipe platform fee: 'percent' | 'flat' | 'both'
# - percent: Fee berdasarkan persentase dari total
# - flat: Fee flat/fixed amount
# - both: Persentase + flat (default: percent)
PLATFORM_FEE_TYPE=percent

# Persentase fee (contoh: 1.15 = 1.15%)
PLATFORM_FEE_PERCENT=1.15

# Flat fee dalam rupiah (contoh: 10000 = Rp 10.000)
PLATFORM_FEE_FLAT=10000

# Xendit Fee Rule ID (untuk xenPlatform Fees)
# Buat di Dashboard: xenPlatform → Fee Rules → Create Fee Rule
# Jika diisi, fee otomatis masuk ke Master Account Xendit
XENDIT_FEE_RULE_ID=

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# OPTIONAL: Other AI Providers
# ============================================================================
# ANTHROPIC_API_KEY=your-anthropic-key
# COHERE_API_KEY=your-cohere-key
# DEEPSEEK_API_KEY=your-deepseek-key
# GEMINI_API_KEY=your-gemini-key
# MISTRAL_API_KEY=your-mistral-key
# PERPLEXITY_API_KEY=your-perplexity-key
